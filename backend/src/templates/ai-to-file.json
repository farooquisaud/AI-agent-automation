{
  "id": "ai-to-file",
  "name": "AI Write To File",
  "description": "Generate AI content and save it to a file.",
  "category": "AI Writing",
  "icon": "📝",
  "tags": ["ai", "file", "automation"],
  "steps": [
    {
      "name": "Generate Content",
      "type": "llm",
      "prompt": "Write detailed content about: {{input.topic}}",
